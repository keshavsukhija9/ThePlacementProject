# ============================================================
# ThePlacementProject — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase (get from: https://supabase.com/dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here   # Service Role key (NOT anon key)

# Swipe (get from: https://dashboard.swipe.co.in/settings/api)
SWIPE_API_KEY=your-swipe-api-key
SWIPE_WEBHOOK_SECRET=your-swipe-webhook-secret

# Telegram Bot (get from: https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# SMS Gateway — Choose ONE provider below

# Option 1: Twilio (https://www.twilio.com)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Option 2: AWS SNS (https://aws.amazon.com/sns/)
# SMS_PROVIDER=aws_sns
# AWS_SNS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# App Config
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
CRON_SECRET=your-secret-for-cron-jobs
# CRON_SECRET is used to protect the daily reminder endpoint
CRON_SECRET=change-this-to-a-random-secret-string
